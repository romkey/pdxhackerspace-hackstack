# Directory to scan for application subdirectories containing .env files with BACKUP_DATABASE_URLS
PARENT_DIR=/opt/docker

# Destination directory for backup files (inside the container, maps from DBBACKUP_DEST_PATH)
DEST_DIR=/dest

# Host path that is mounted as /opt inside the container (must contain PARENT_DIR)
DBBACKUP_PARENT_HOST_PATH=/opt

# Host path for backup storage, mounted as /dest inside the container
DBBACKUP_DEST_PATH=/backups/chaos/databases

# Slack webhook URL for backup notifications (optional)
#SLACK_WEBHOOK_URL=

# Backup interval in minutes (default: 60)
BACKUP_INTERVAL_MINUTES=60

# Tiered backup retention (number of backups to keep at each tier, default: 6)
BACKUP_RETAIN_HOURLY=6
BACKUP_RETAIN_DAILY=6
BACKUP_RETAIN_WEEKLY=6
BACKUP_RETAIN_MONTHLY=6
BACKUP_RETAIN_YEARLY=6

# Image version (optional, defaults to latest)
#IMAGE_VERSION=latest
