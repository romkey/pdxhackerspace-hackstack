# PostgreSQL connection
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
# Comma-separated list of databases to back up (leave empty for all)
POSTGRES_DATABASES=

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 3 * * *

# How many days of backups to retain
BACKUP_RETENTION_DAYS=7

# Image version (optional, defaults to latest)
#IMAGE_VERSION=latest
