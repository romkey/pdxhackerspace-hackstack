# Path to the GGUF model file inside the container
LLAMA_ARG_MODEL=/models/model.gguf

# Number of GPU layers to offload (0 = CPU only, -1 = all layers)
LLAMA_ARG_N_GPU_LAYERS=0

# Context window size in tokens
LLAMA_ARG_CTX_SIZE=4096

# Number of CPU threads to use
LLAMA_ARG_THREADS=4

# Bind host and port inside the container
LLAMA_ARG_HOST=0.0.0.0
LLAMA_ARG_PORT=8080

# Image tag controls the hardware backend:
#   server        - CPU only (default)
#   server-cuda   - NVIDIA GPU (requires nvidia container runtime)
#   server-rocm   - AMD GPU (requires ROCm)
#   server-vulkan - Vulkan (Intel/AMD integrated)
#IMAGE_VERSION=server
