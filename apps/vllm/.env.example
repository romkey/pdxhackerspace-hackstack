# Required: Hugging Face model id, or a path to weights visible inside the container
VLLM_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Optional: extra vLLM engine (CLI) flags — space-separated, same as after `vllm serve` in the docs
# VLLM_ARGS=--max-model-len 8192 --tensor-parallel-size 1

# vLLM image tag (CUDA); use a matching vllm version, e.g. a release tag or latest
# For AMD ROCm, use image vllm/vllm-openai-rocm in docker-compose — see README
# IMAGE_VERSION=latest

# Number of NVIDIA GPUs to expose to the container (0 may still start the process but is unusual for vLLM)
# GPU_COUNT=1

# Hugging Face token for gated models (optional; can also be set in .env without prefix)
# HF_TOKEN=
