# Matrix homeserver public domain (e.g. matrix.example.com)
# This becomes the user ID suffix:  @user:SYNAPSE_SERVER_NAME
SYNAPSE_SERVER_NAME=matrix.example.com

# Set to "yes" to report anonymised usage statistics to matrix.org
SYNAPSE_REPORT_STATS=no

# PostgreSQL connection for Synapse (uses the shared postgresql service)
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=matrix_db
POSTGRES_USER=matrix_user
POSTGRES_PASSWORD=

# A long random secret used to register new users via the API.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SYNAPSE_REGISTRATION_SHARED_SECRET=

# A long random secret for the Macaroon used to sign access tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SYNAPSE_MACAROON_SECRET_KEY=

# Image versions (leave blank to use latest)
#SYNAPSE_IMAGE_VERSION=latest
#ELEMENT_IMAGE_VERSION=latest
