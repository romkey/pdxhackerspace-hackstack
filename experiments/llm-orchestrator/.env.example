# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
# JSON array of model definitions. Each entry:
#   name        - the model name clients send in requests (e.g. "llama-3-8b")
#   hf_name     - HuggingFace model ID
#   vram_gb     - VRAM required; used to pick which GPU to assign
#
MODELS='[
  {"name": "llama-3-8b",  "hf_name": "meta-llama/Llama-3.1-8B-Instruct",  "vram_gb": 18},
  {"name": "mistral-7b",  "hf_name": "mistralai/Mistral-7B-Instruct-v0.3", "vram_gb": 16},
  {"name": "qwen-14b",    "hf_name": "Qwen/Qwen2.5-14B-Instruct",          "vram_gb": 30}
]'

# =============================================================================
# HUGGING FACE
# =============================================================================
# Required for gated models (Llama, Mistral, etc.)
# Get yours at https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_token_here

# =============================================================================
# ORCHESTRATOR SETTINGS
# =============================================================================

# How many seconds a model can sit idle before its container is stopped
IDLE_TIMEOUT_SECONDS=600

# Maximum number of models to run concurrently.
# Set based on how many GPUs / how much total VRAM you have.
MAX_CONCURRENT_MODELS=2

# Fraction of each GPU's memory vLLM may use (0.0 - 1.0)
GPU_MEMORY_UTILIZATION=0.90

# Port the orchestrator HTTP API listens on
ORCHESTRATOR_PORT=8000

# Seconds to wait for a vLLM container to become healthy after starting
STARTUP_TIMEOUT_SECONDS=180

# How often the idle-watcher background loop runs (seconds)
IDLE_CHECK_INTERVAL_SECONDS=60

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# vLLM Docker image to use for model containers
VLLM_IMAGE=vllm/vllm-openai:latest

# =============================================================================
# LITELLM SETTINGS
# =============================================================================

# URL LiteLLM uses to reach the orchestrator.
# When both run in the same Compose stack, use the service name:
ORCHESTRATOR_URL=http://orchestrator:8000
# When LiteLLM is on a different machine, use the GPU machine's address:
# ORCHESTRATOR_URL=http://gpu-machine-1:8000

# External port LiteLLM listens on
LITELLM_PORT=4000

# Optional: API key clients must send to LiteLLM
# LITELLM_MASTER_KEY=sk-your-secret-key

# Optional: Postgres connection string for spend/key tracking
# DATABASE_URL=postgresql://user:password@localhost:5432/litellm

# =============================================================================
# DOCKER / STORAGE SETTINGS
# =============================================================================

# Absolute path on the HOST where HuggingFace models are cached.
# This path is bind-mounted into both the orchestrator and each vLLM container.
# Must be an absolute path — tilde expansion does not work in Docker volume mounts.
HF_CACHE_DIR=/home/youruser/.cache/huggingface
