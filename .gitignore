# Do not edit .gitignore - the file is assembled automatically by a Github action
# from */.gitignore files and .gitignore.initial on pushes to the repo
#
# To add to .gitignore either edit the related .gitignore file in a subdirectory
# or edit .gitignore.initial
#
# Be sure to git pull after pushing .gitignore modifications and after the action
# runs, so that you get the updated .gitignore file in your local environment

**/*.env

*~

lib/*
log/*
run/*
local/

# [apps] apps/access-control-webhook/.gitignore
apps/access-control-webhook/config/.ssh/
apps/access-control-webhook/config/hooks.json
apps/access-control-webhook/config/run/automation_rsa

# [apps] apps/airconnect/.gitignore
apps/airconnect/config/*.xml

# [apps] apps/autogenerate-hosts/.gitignore
apps/autogenerate-hosts/.env
apps/autogenerate-hosts/app/npm-hosts

# [apps] apps/backrest/.gitignore
apps/backrest/config/config.json*

# [apps] apps/caddy-home-assistant-liar/.gitignore
apps/caddy-home-assistant-liar/config/Caddyfile

# [apps] apps/cups/.gitignore
apps/cups/config/cupsd.conf

# [apps] apps/dnsmasq/.gitignore
apps/dnsmasq/config/dnsmasq.conf
apps/dnsmasq/config/hosts.d/

# [apps] apps/glances/.gitignore
apps/glances/glances.conf
apps/glances/glances.pwd

# [apps] apps/invidious/.gitignore
apps/invidious/config/config.yml
apps/invidious/config/sql/

# [apps] apps/jellyfin/.gitignore
apps/jellyfin/config/

# [apps] apps/mopidy/.gitignore
apps/mopidy/config/mopidy.conf

# [apps] apps/mosquitto/.gitignore
apps/mosquitto/config/mosquitto.conf
apps/mosquitto/config/mos_passwd

# [apps] apps/mqtt-explorer/.gitignore
apps/mqtt-explorer/config/settings.json

# [apps] apps/nginx-proxy-manager/.gitignore
apps/nginx-proxy-manager/config/
apps/nginx-proxy-manager/letsencrypt/

# [apps] apps/peanut/.gitignore
apps/peanut/config/settings.yml

# [apps] apps/shairport-sync/.gitignore
apps/shairport-sync/config/shairport-sync.conf

# [apps] apps/snapserver/.gitignore
apps/snapserver/config/snapcast.conf

# [apps] apps/upsd/.gitignore
apps/upsd/config/entrypoint.sh
apps/upsd/config/ups.conf
apps/upsd/config/upsd.conf
apps/upsd/config/upsd.users
apps/upsd/config/upsmon.conf

# [apps] apps/wiki/.gitignore
apps/wiki/config.yml

# [apps] apps/zigbee2mqtt/.gitignore
apps/zigbee2mqtt/config/configuration.yaml
apps/zigbee2mqtt/config/coordinator_backup.json
apps/zigbee2mqtt/config/state.json
apps/zigbee2mqtt/config/database.db
apps/zigbee2mqtt/config/log/

# [experiments] experiments/grafana/.gitignore
experiments/grafana/config/grafana.ini

# [experiments] experiments/homebox/.gitignore
experiments/homebox/.env

# [experiments] experiments/influxdb/.gitignore
experiments/influxdb/config/influx-configs

# [experiments] experiments/nextcloud/.gitignore
experiments/nextcloud/.env

# [experiments] experiments/rtlamr2mqtt/.gitignore
experiments/rtlamr2mqtt/.env
experiments/rtlamr2mqtt/config/rtlamr2mqtt.yaml

# [experiments] experiments/telegraf/.gitignore
experiments/telegraf/config/telegraf.conf
